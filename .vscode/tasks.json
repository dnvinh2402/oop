{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compile SFML Project",
            "command": "g++",
            "args": [
                "-std=c++17",
                "${file}",
                "-o",
                "${workspaceFolder}/build/${fileBasenameNoExtension}.exe",
                "-I",
                "C:/msys64/ucrt64/include",
                "-L",
                "C:/msys64/ucrt64/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}